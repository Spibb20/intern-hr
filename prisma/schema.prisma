generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model employee {
  employee_id          Int       @id @default(autoincrement())
  name                 String    @db.Char(25)
  surname              String?   @db.Char(25)
  dep_ident            Int?      @db.SmallInt
  post                 String?   @db.Char(25)
  birthday             DateTime?
  emdno                String?   @db.Char(14)
  ndno                 String?   @db.Char(14)
  working_year         Int       @default(0) @db.SmallInt
  wskill_ident         Int?
  salary               Decimal   @default(0) @db.Decimal(18, 15)
  inworkdate           DateTime?
  g_date               DateTime?
  g_enddate            DateTime?
  homephone            String?   @db.Char(14)
  workphone            String?   @db.Char(14)
  fullname             String?   @db.VarChar(208)
  calctype             Int?      @db.SmallInt
  workcondtn           Int?      @db.SmallInt
  status               String?   @default("active") @db.Char(8)
  manager_exp          String?   @default("no") @db.VarChar(12)
  occupation_ident     Int?
  grade                String?   @db.Char(1)
  gender               String?   @db.Char(1)
  education_ident      Int?
  graduate_ident       Int?
  ecode                String?   @db.Char(20)
  is_soldier           String?   @db.Char(3)
  loginpass            String?   @db.VarChar(20)
  bycard               Int?      @db.SmallInt
  email                String?   @db.VarChar(50)
  bank_ident           Int?
  branch_ident         Int?
  schedule             Int?
  registerno           String?   @db.VarChar(20)
  tenderer             Int?      @db.SmallInt
  ten_days             Int?      @db.SmallInt
  asset_owner          Int?      @default(1) @db.SmallInt
  item_owner           Int?      @default(1) @db.SmallInt
  registered_date      DateTime?
  ovog                 String?   @db.Char(25)
  job_type             String?   @db.VarChar(20)
  job_figure           String?   @default("Main") @db.VarChar(20)
  maritalstatus_ident  Int?
  apartcond_ident      Int?
  carowncond_ident     Int?
  contract_num         String?   @db.Char(10)
  nationality_ident    Int?
  niigmiin_garal_ident Int?
  country_ident        Int?
  voting_work_ident    Int?
  degree_ident         Int?
  passport             String?   @db.VarChar(14)
  clothessize_ident    Int?
  shoessize_ident      Int?
  income               Int?
  contract_emp         String    @default("no") @db.VarChar(12)
  branchyear           Int?
  birthyear            Int?
  died                 String    @default("no") @db.VarChar(12)
  hr                   String    @default("no") @db.VarChar(12)
  realtor              Int?      @db.SmallInt
  insur_ident          Int?
  limited              Int?      @db.SmallInt
  loc_code             String?   @db.VarChar(4)
  ibank_number         String?   @db.VarChar(20)
  blood_type           String?   @db.Char(2)
  emptype              Int?      @db.SmallInt
  changed_date         DateTime?
  command_ident        Int?
  move_type            Int?      @db.SmallInt
  workyear_sector      Int       @default(0) @db.SmallInt
  firedreason_ident    Int?
  taken_leave          Int?      @db.SmallInt
  leave_type           Int?      @db.SmallInt
  test_month           Int?      @db.SmallInt
  foreign_emp          Int?      @db.SmallInt
  wagetest_emp         Int?      @db.SmallInt
  office_ident         Int?
  section_ident        Int?
  empno                String?   @db.VarChar(10)
  grade_perc           Decimal   @default(0) @db.Decimal(18, 15)
  perc1                Decimal   @default(0) @db.Decimal(18, 15)
  perc2                Decimal   @default(0) @db.Decimal(18, 15)
  phone2               String?   @db.VarChar(14)
  grade_amount         Decimal   @default(0) @db.Decimal(18, 15)
  grade_start          DateTime?
  grade_end            DateTime?
  grade_level          String?   @db.VarChar(10)
  occupation_ident2    Int?
  sal_percent          Decimal   @default(0) @db.Decimal(18, 15)
  sal_amount           Decimal   @default(0) @db.Decimal(18, 15)
  wtype                Int?      @db.SmallInt
  disabled_emp         Int?      @db.SmallInt
  photo_url            String?   @db.VarChar(300)
  pos_related          Boolean?
  etax_code            String?   @db.VarChar(30)
  urgiin_ovog          String?   @db.VarChar(100)
  command_no           String?   @db.VarChar(10)
  command_description  String?   @db.VarChar(100)
  auth_usercompany_id  Int?
  timetry_id           String?   @db.VarChar(25)
  use_timetry          Int?      @db.SmallInt
  auth_user_id         Int?

  dep            deps?              @relation(fields: [dep_ident], references: [dep_id], onDelete: SetNull)
  work_skill     work_skill?        @relation(fields: [wskill_ident], references: [wskill_id], onDelete: SetNull)
  occupation     occupation?        @relation("EmployeeOccupation", fields: [occupation_ident], references: [occupation_id], onDelete: SetNull)
  occupation2    occupation?        @relation("EmployeeOccupation2", fields: [occupation_ident2], references: [occupation_id], onDelete: SetNull)
  education      education?         @relation(fields: [education_ident], references: [education_id], onDelete: SetNull)
  graduate       graduate?          @relation(fields: [graduate_ident], references: [graduate_id], onDelete: SetNull)
  bank           banks?             @relation(fields: [bank_ident], references: [bank_id], onDelete: SetNull)
  branch         branch?            @relation(fields: [branch_ident], references: [branch_id], onDelete: SetNull)
  shift          shifts?            @relation(fields: [schedule], references: [id], onDelete: SetNull)
  marital_status marital_status?    @relation(fields: [maritalstatus_ident], references: [maritalstatus_id], onDelete: SetNull)
  apartment_cond apartment_cond?    @relation(fields: [apartcond_ident], references: [apartcond_id], onDelete: SetNull)
  carown_cond    carown_cond?       @relation(fields: [carowncond_ident], references: [carowncond_id], onDelete: SetNull)
  nationality    nationality?       @relation(fields: [nationality_ident], references: [nationality_id], onDelete: SetNull)
  niigmiin_garal niigmiin_garal?    @relation(fields: [niigmiin_garal_ident], references: [niigmiin_garal_id], onDelete: SetNull)
  country        country?           @relation(fields: [country_ident], references: [country_ident], onDelete: SetNull)
  voting_work    voting_work?       @relation(fields: [voting_work_ident], references: [voting_work_id], onDelete: SetNull)
  degree         degree?            @relation(fields: [degree_ident], references: [degree_id], onDelete: SetNull)
  clothes_size   clothes_size_type? @relation("EmployeeClothesSize", fields: [clothessize_ident], references: [typeid], onDelete: SetNull)
  shoes_size     clothes_size_type? @relation("EmployeeShoesSize", fields: [shoessize_ident], references: [typeid], onDelete: SetNull)
  insur_type     insur_type?        @relation(fields: [insur_ident], references: [insur_id], onDelete: SetNull)
  fired_reason   fired_reason?      @relation(fields: [firedreason_ident], references: [firedreason_id], onDelete: SetNull)
  office         hr_office?         @relation(fields: [office_ident], references: [office_id], onDelete: SetNull)

  foreign_languages  foreign_lang[]
  hr_trainings       hr_training[]
  emp_photos         emp_photo[]
  employee_histories employee_history[]
  drivers            driver[]
  educs              educ[]
  spec_edus          spec_edu[]
  emp_grades         emp_grade[]
  emp_vacations      emp_vacation[]
  hr_absents         hr_absents[]
  commands           command[]
  emp_assets         emp_assets[]
  emp_talents        emp_talents[]

  @@index([dep_ident])
  @@index([occupation_ident])
  @@index([occupation_ident2])
  @@index([education_ident])
  @@index([graduate_ident])
  @@index([bank_ident])
  @@index([branch_ident])
  @@index([country_ident])
  @@index([nationality_ident])
  @@index([degree_ident])
  @@index([niigmiin_garal_ident])
  @@index([voting_work_ident])
  @@index([clothessize_ident])
  @@index([shoessize_ident])
  @@index([apartcond_ident])
  @@index([carowncond_ident])
  @@index([wskill_ident])
  @@index([schedule])
  @@index([firedreason_ident])
  @@index([insur_ident])
  @@index([maritalstatus_ident])
  @@index([office_ident])
  @@index([registerno])
  @@index([status])
}

model deps {
  dep_id            Int     @id @default(autoincrement()) @db.SmallInt
  name              String? @db.Char(25)
  parent_id         Int?    @db.SmallInt
  acc_num           String? @db.Char(12)
  cust_ident        Int?
  exptype_ident     Int?
  socins_acc        String? @db.Char(12)
  schedule          Int?
  sclass            Int?    @db.SmallInt
  office_ident      Int?
  list_acc          String? @db.Char(12)
  porder            Int?    @db.SmallInt
  print_columns     String? @db.VarChar(500)
  print_columns_adv String? @db.VarChar(500)

  parent    deps?      @relation("DepsTree", fields: [parent_id], references: [dep_id], onDelete: SetNull)
  children  deps[]     @relation("DepsTree")
  shift     shifts?    @relation(fields: [schedule], references: [id], onDelete: SetNull)
  office    hr_office? @relation(fields: [office_ident], references: [office_id], onDelete: SetNull)
  employees employee[]

  @@index([parent_id])
  @@index([schedule])
  @@index([office_ident])
}

model occupation {
  occupation_id        Int     @id @default(autoincrement())
  description          String  @db.Char(100)
  fdbexp_ident         Int?
  occup                Int?    @db.SmallInt
  occupation_character String? @db.VarChar(20)
  sched_id             Int?
  oclass_code          String? @db.VarChar(4)
  oclass_code2024      String? @db.VarChar(10)

  schedule   schedule?  @relation(fields: [sched_id], references: [sched_id], onDelete: SetNull)
  employees  employee[] @relation("EmployeeOccupation")
  employees2 employee[] @relation("EmployeeOccupation2")

  @@index([sched_id])
}

model education {
  education_id Int    @id @default(autoincrement())
  description  String @db.Char(25)

  employees employee[]
}

model banks {
  bank_id       Int       @id @default(autoincrement())
  description   String?   @db.VarChar(100)
  email         String?   @db.VarChar(50)
  phone         String?   @db.VarChar(15)
  recacc        String?   @db.Char(12)
  reccust_ident Int?
  bank_code     String?   @db.VarChar(20)
  address       String?   @db.VarChar(70)
  country_ident Int?
  modified_date DateTime?
  bic_code      String?   @db.VarChar(20)
  banknumber    String?   @db.VarChar(20)
  code_salary   String?   @db.VarChar(20)

  country   country?   @relation(fields: [country_ident], references: [country_ident], onDelete: SetNull)
  employees employee[]

  @@index([country_ident])
}

model country {
  country_ident Int     @id @default(autoincrement())
  description   String  @db.VarChar(50)
  country_code  String? @db.VarChar(10)
  code4bank     String? @db.VarChar(5)

  employees employee[]
  banks     banks[]
}

model nationality {
  nationality_id Int    @id @default(autoincrement())
  description    String @db.Char(50)

  employees employee[]
}

model citytown {
  city_id     Int     @id @default(autoincrement())
  description String  @db.VarChar(50)
  region_code String? @db.VarChar(10)

  districts district[]
}

model district {
  district_id Int     @id @default(autoincrement())
  description String  @db.VarChar(50)
  code        Int?
  loc_code    Int?
  city_ident  Int
  region_code String? @db.VarChar(10)

  city citytown @relation(fields: [city_ident], references: [city_id])

  @@index([city_ident])
}

model marital_status {
  maritalstatus_id Int     @id @default(autoincrement())
  description      String? @db.Char(30)
  rpl_local        String? @default("N") @db.Char(1)

  employees employee[]
}

model apartment_cond {
  apartcond_id Int     @id @default(autoincrement())
  description  String  @db.VarChar(50)
  rpl_local    String? @default("N") @db.Char(1)

  employees employee[]
}

model carown_cond {
  carowncond_id Int     @id @default(autoincrement())
  description   String  @db.VarChar(50)
  rpl_local     String? @default("N") @db.Char(1)

  employees employee[]
}

model niigmiin_garal {
  niigmiin_garal_id Int     @id @default(autoincrement())
  description       String  @db.VarChar(50)
  rpl_local         String? @default("N") @db.Char(1)

  employees employee[]
}

model voting_work {
  voting_work_id Int    @id @default(autoincrement())
  description    String @db.VarChar(50)

  employees employee[]
}

model graduate {
  graduate_id Int    @id @default(autoincrement())
  description String @db.Char(25)

  employees employee[]
}

model insur_type {
  insur_id      Int      @id @default(autoincrement())
  insur_code    String?  @db.VarChar(10)
  description   String?  @db.VarChar(100)
  sal_type      Int?     @db.SmallInt
  ins_order     Int?
  colnum        Int?     @db.SmallInt
  ndsh_percent  Decimal? @db.Decimal(18, 2)
  emp_percent   Decimal? @db.Decimal(18, 2)
  insur_codenew String?  @db.VarChar(10)

  employees employee[]
}

model fired_reason {
  firedreason_id Int    @id @default(autoincrement())
  description    String @db.VarChar(100)

  employees employee[]
}

model clothes_size_type {
  typeid           Int     @id @default(autoincrement())
  clothessize      String  @db.Char(10)
  sizetype         String  @db.Char(7)
  size_other_man   String? @db.Char(10)
  size_other_woman String? @db.Char(10)

  clothes_employees employee[] @relation("EmployeeClothesSize")
  shoes_employees   employee[] @relation("EmployeeShoesSize")
}

model work_skill {
  wskill_id   Int     @id @default(autoincrement())
  description String  @db.Char(25)
  cost_normal Decimal @default(0) @db.Decimal(18, 15)
  cost_hard   Decimal @default(0) @db.Decimal(18, 15)
  cost_other  Decimal @default(0) @db.Decimal(18, 15)

  employees employee[]
}

model branch {
  branch_id        Int       @id @default(autoincrement())
  description      String    @db.Char(25)
  boss             String?   @db.Char(30)
  gen_accountant   String?   @db.Char(30)
  status           Int       @db.SmallInt
  legal_name       String?   @db.Char(40)
  address          String?   @db.Char(90)
  registerno       String?   @db.Char(20)
  ttd              String?   @db.Char(20)
  org_type         String?   @db.Char(25)
  accountant       String?   @db.Char(25)
  custid           Int?
  manager          Int?
  bankname         String?   @db.VarChar(30)
  banknumber       String?   @db.VarChar(20)
  phone            String?   @db.VarChar(60)
  hrmanager        String?   @db.VarChar(30)
  tradeunion_name  String?   @db.VarChar(100)
  tradeunion_assoc String?   @db.VarChar(100)
  tradeunion_head  String?   @db.VarChar(100)
  chkdate          DateTime?
  logo             Bytes?
  is_sync          String?   @db.VarChar(3)
  modified_date    DateTime?
  boss_sign1       Bytes?
  account_sign1    Bytes?
  stamp_acc        Bytes?
  stamp_boss       Bytes?
  emd_cust         Int?
  emdacc           String?   @db.Char(12)
  taxable          String?   @db.VarChar(12)
  email            String?   @db.VarChar(100)

  employees employee[]
}

model hr_office {
  office_id Int    @id @default(autoincrement())
  name      String @db.VarChar(100)

  deps      deps[]
  employees employee[]
}

model shifts {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(20)

  deps      deps[]
  employees employee[]
}

model schedule {
  sched_id   Int    @id @default(autoincrement())
  sched_name String @db.VarChar(30)
  work_day   Int
  holiday    Int

  occupations occupation[]
}

model profession_type {
  professiontype_id Int    @id @default(autoincrement())
  description       String @db.Char(100)
}

model edu_type {
  education_id Int     @id @default(autoincrement())
  name         String  @db.VarChar(50)
  rpl_local    String? @default("N") @db.Char(1)

  educs educ[]
}

model educ {
  educ_id        Int       @id @default(autoincrement()) @db.SmallInt
  employee_ident Int
  edu_ident      Int
  startdate      DateTime?
  start_year     Int       @db.SmallInt

  employee employee @relation(fields: [employee_ident], references: [employee_id], onDelete: Cascade)
  edu_type edu_type @relation(fields: [edu_ident], references: [education_id])

  @@index([employee_ident])
  @@index([edu_ident])
}

model spec_edu_type {
  spec_edu_type_id Int    @id @default(autoincrement())
  description      String @db.Char(30)

  spec_edus spec_edu[]
}

model spec_edu {
  spec_edu_id         Int       @id @default(autoincrement())
  employee_ident      Int
  spec_edu_type_ident Int
  org_edu             String    @db.VarChar(30)
  certify_number      String?   @db.Char(20)
  certify_date        DateTime?
  profession          String?   @db.VarChar(20)
  end_date            DateTime?
  spec_profession     String?   @db.VarChar(20)
  certify_year        Int       @db.SmallInt

  employee      employee      @relation(fields: [employee_ident], references: [employee_id], onDelete: Cascade)
  spec_edu_type spec_edu_type @relation(fields: [spec_edu_type_ident], references: [spec_edu_type_id])

  @@index([employee_ident])
  @@index([spec_edu_type_ident])
}

model flanguages {
  flanguage_id Int     @id @default(autoincrement())
  description  String  @db.Char(30)
  rpl_local    String? @default("N") @db.Char(1)

  foreign_langs foreign_lang[]
}

model lang_level {
  langlevel_id Int    @id @default(autoincrement())
  level_name   String @db.VarChar(50)
}

model foreign_lang {
  foreignlang_id  Int     @id @default(autoincrement())
  employee_ident  Int
  flanguage_ident Int
  understand_lvl  String? @db.Char(15)
  speaking_lvl    String? @db.Char(15)
  reading_lvl     String? @db.Char(15)
  writing_lvl     String? @db.Char(15)
  description     String? @db.VarChar(50)

  employee employee   @relation(fields: [employee_ident], references: [employee_id], onDelete: Cascade)
  language flanguages @relation(fields: [flanguage_ident], references: [flanguage_id])

  @@index([employee_ident])
  @@index([flanguage_ident])
}

model hr_training {
  training_id     Int       @id @default(autoincrement())
  emp_ident       Int
  tr_type         Int       @default(1) @db.SmallInt
  description     String    @db.VarChar(50)
  start_date      DateTime?
  days            Int?      @db.SmallInt
  amount          Decimal   @default(0) @db.Decimal(18, 15)
  pay_type        Int       @db.SmallInt
  training_center String?   @db.VarChar(100)
  start_year      Int       @db.SmallInt

  employee employee @relation(fields: [emp_ident], references: [employee_id])

  @@index([emp_ident])
}

model emp_photo {
  photo_id Int    @id @default(autoincrement())
  emp_id   Int
  photo    Bytes?

  employee employee @relation(fields: [emp_id], references: [employee_id])

  @@index([emp_id])
}

model employee_history {
  history_id          Int       @id @default(autoincrement())
  employee_ident      Int
  name                String    @db.Char(25)
  surname             String?   @db.Char(25)
  post                String?   @db.Char(25)
  birthday            DateTime?
  emdno               String?   @db.Char(14)
  ndno                String?   @db.Char(14)
  working_year        Int       @default(0) @db.SmallInt
  salary              Decimal   @default(0) @db.Decimal(18, 2)
  inworkdate          DateTime?
  g_date              DateTime?
  g_enddate           DateTime?
  homephone           String?   @db.Char(14)
  workphone           String?   @db.Char(14)
  calctype            Int?      @db.SmallInt
  status              String?   @default("active") @db.Char(8)
  manager_exp         String?   @default("no") @db.VarChar(3)
  occupation_ident    Int?
  gender              String?   @db.Char(1)
  education_ident     Int?
  graduate_ident      Int?
  ecode               String?   @db.Char(20)
  bycard              Int?      @db.SmallInt
  email               String?   @db.VarChar(50)
  register            String?   @db.VarChar(20)
  passport            String?   @db.VarChar(20)
  inworknumber        String?   @db.VarChar(10)
  address             String?   @db.VarChar(100)
  ndsh_deps           Int?
  hoat_deps           Int?
  fired_number        String?   @db.VarChar(10)
  fired_date          DateTime?
  fired_ident         Int?
  dep_ident           Int?
  s_ident             Int?
  bonus               String?   @db.VarChar(20)
  workcondtn          Int?      @db.SmallInt
  country_ident       Int?
  country1_ident      Int?
  changed_date        DateTime?
  comand_no           String?   @db.VarChar(10)
  command_ident       Int?
  contract_emp        String?   @default("no") @db.VarChar(12)
  branch_ident        Int?
  move_type           Int?      @db.SmallInt
  firedreason_ident   Int?
  emptype             Int?      @db.SmallInt
  fullname            String?   @db.VarChar(208)
  isdefault           Int?      @db.SmallInt
  foreign_emp         Int?      @db.SmallInt
  wagetest_emp        Int?      @db.SmallInt
  command_description String?   @db.VarChar(100)
  insur_ident         Int?

  employee employee @relation(fields: [employee_ident], references: [employee_id])

  @@index([employee_ident])
}

model driver_type {
  driver_type_id Int     @id @default(autoincrement())
  description    String  @db.VarChar(30)
  rpl_local      String? @default("N") @db.Char(1)

  drivers driver[]
}

model driver {
  id_driver      Int       @id @default(autoincrement())
  employee_ident Int
  number_driver  String?   @db.VarChar(15)
  inserted_ognoo DateTime?
  drivertype     Int

  employee    employee    @relation(fields: [employee_ident], references: [employee_id], onDelete: Cascade)
  driver_type driver_type @relation(fields: [drivertype], references: [driver_type_id])

  @@index([employee_ident])
  @@index([drivertype])
}

model emp_grade {
  grade_id    Int       @id @default(autoincrement())
  emp_ident   Int?
  grade_level String?   @db.VarChar(100)
  grade_start DateTime?
  grade_end   DateTime?
  sal_amount  Decimal   @default(0) @db.Decimal(18, 15)

  employee employee? @relation(fields: [emp_ident], references: [employee_id], onDelete: SetNull)

  @@index([emp_ident])
}

model emp_vacation {
  emp_ident   Int
  xmonth      Int?      @default(0) @db.SmallInt
  dep_ident   Int?
  myear       Int       @db.SmallInt
  mmonth      Int       @db.SmallInt
  is_vacation String?   @default("no") @db.VarChar(12)
  v_day       Int       @default(0) @db.SmallInt
  start_date  DateTime?
  end_date    DateTime?

  employee employee @relation(fields: [emp_ident], references: [employee_id], onDelete: Cascade)

  @@id([emp_ident, myear, mmonth])
}

model hr_absents {
  absent_id   Int      @id @default(autoincrement())
  emp_ident   Int
  absent_type Int      @db.SmallInt
  days        Int?     @db.SmallInt
  times       Int?     @db.SmallInt
  minutes     Int?     @db.SmallInt
  time_str    String?  @db.VarChar(20)
  adate       DateTime

  employee employee @relation(fields: [emp_ident], references: [employee_id], onDelete: Cascade)

  @@index([emp_ident])
}

model command {
  command_id     Int       @id @default(autoincrement())
  employee_ident Int
  command        String?   @db.VarChar(50)
  outdate        DateTime?
  human_command  String?   @db.VarChar(25)
  commandno      String    @db.VarChar(10)
  path           String?   @db.VarChar(100)
  rpl_local      String?   @default("N") @db.Char(1)
  command_type   Int?      @db.SmallInt

  employee employee @relation(fields: [employee_ident], references: [employee_id], onDelete: Cascade)

  @@index([employee_ident])
}

model emp_assets {
  empasset_id      Int       @id @default(autoincrement())
  emp_ident        Int
  asset_ident      Int
  sdate            DateTime?
  inactive_date    DateTime?
  quantity         Decimal   @default(0) @db.Decimal(18, 15)
  inactiv          Int?      @default(0) @db.SmallInt
  assettrans_ident Int?
  barcode          String?   @db.VarChar(30)
  atype            Int?      @db.SmallInt
  master_id        Int?
  user_name        String    @default("system") @db.Char(20)
  atr_id           Int?

  employee employee @relation(fields: [emp_ident], references: [employee_id])

  @@index([emp_ident])
}

model emp_talents {
  emp_ident    Int
  talent_ident Int
  trained_year Int?    @db.SmallInt
  description  String? @db.VarChar(200)

  employee employee @relation(fields: [emp_ident], references: [employee_id])
  talent   talents  @relation(fields: [talent_ident], references: [talent_id], onDelete: Cascade)

  @@id([emp_ident, talent_ident])
  @@index([talent_ident])
}

model degree {
  degree_id   Int     @id @default(autoincrement())
  description String  @db.VarChar(30)
  rpl_local   String? @default("N") @db.Char(1)

  employees employee[]
}

model talents {
  talent_id   Int    @id @default(autoincrement())
  description String @unique @db.Char(30)

  emp_talents emp_talents[]
}
