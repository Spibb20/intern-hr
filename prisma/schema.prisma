generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  employeeId         Int       @id @default(autoincrement()) @map("employee_id")
  name               String    @map("name") @db.Char(25)
  surname            String?   @map("surname") @db.Char(25)
  depIdent           Int?      @map("dep_ident") @db.SmallInt
  post               String?   @map("post") @db.Char(25)
  birthday           DateTime? @map("birthday")
  emdno              String?   @map("emdno") @db.Char(14)
  ndno               String?   @map("ndno") @db.Char(14)
  workingYear        Int       @default(0) @map("working_year") @db.SmallInt
  wskillIdent        Int?      @map("wskill_ident")
  salary             Decimal   @default(0) @map("salary") @db.Decimal(18, 15)
  inworkdate         DateTime? @map("inworkdate")
  gDate              DateTime? @map("g_date")
  gEnddate           DateTime? @map("g_enddate")
  homephone          String?   @map("homephone") @db.Char(14)
  workphone          String?   @map("workphone") @db.Char(14)
  fullname           String?   @map("fullname") @db.VarChar(208)
  calctype           Int?      @map("calctype") @db.SmallInt
  workcondtn         Int?      @map("workcondtn") @db.SmallInt
  status             String?   @default("active") @map("status") @db.Char(8)
  managerExp         String?   @default("no") @map("manager_exp") @db.VarChar(12)
  occupationIdent    Int?      @map("occupation_ident")
  grade              String?   @map("grade") @db.Char(1)
  gender             String?   @map("gender") @db.Char(1)
  educationIdent     Int?      @map("education_ident")
  graduateIdent      Int?      @map("graduate_ident")
  ecode              String?   @map("ecode") @db.Char(20)
  isSoldier          String?   @map("is_soldier") @db.Char(3)
  loginpass          String?   @map("loginpass") @db.VarChar(20)
  bycard             Int?      @map("bycard") @db.SmallInt
  email              String?   @map("email") @db.VarChar(50)
  bankIdent          Int?      @map("bank_ident")
  branchIdent        Int?      @map("branch_ident")
  schedule           Int?      @map("schedule")
  registerno         String?   @map("registerno") @db.VarChar(20)
  tenderer           Int?      @map("tenderer") @db.SmallInt
  tenDays            Int?      @map("ten_days") @db.SmallInt
  assetOwner         Int?      @default(1) @map("asset_owner") @db.SmallInt
  itemOwner          Int?      @default(1) @map("item_owner") @db.SmallInt
  registeredDate     DateTime? @map("registered_date")
  ovog               String?   @map("ovog") @db.Char(25)
  jobType            String?   @map("job_type") @db.VarChar(20)
  jobFigure          String?   @default("Main") @map("job_figure") @db.VarChar(20)
  maritalstatusIdent Int?      @map("maritalstatus_ident")
  apartcondIdent     Int?      @map("apartcond_ident")
  carowncondIdent    Int?      @map("carowncond_ident")
  contractNum        String?   @map("contract_num") @db.Char(10)
  nationalityIdent   Int?      @map("nationality_ident")
  niigmiinGaralIdent Int?      @map("niigmiin_garal_ident")
  countryIdent       Int?      @map("country_ident")
  votingWorkIdent    Int?      @map("voting_work_ident")
  degreeIdent        Int?      @map("degree_ident")
  passport           String?   @map("passport") @db.VarChar(14)
  clothessizeIdent   Int?      @map("clothessize_ident")
  shoessizeIdent     Int?      @map("shoessize_ident")
  income             Int?      @map("income")
  contractEmp        String    @default("no") @map("contract_emp") @db.VarChar(12)
  branchyear         Int?      @map("branchyear")
  birthyear          Int?      @map("birthyear")
  died               String    @default("no") @map("died") @db.VarChar(12)
  hr                 String    @default("no") @map("hr") @db.VarChar(12)
  realtor            Int?      @map("realtor") @db.SmallInt
  insurIdent         Int?      @map("insur_ident")
  limited            Int?      @map("limited") @db.SmallInt
  locCode            String?   @map("loc_code") @db.VarChar(4)
  ibankNumber        String?   @map("ibank_number") @db.VarChar(20)
  bloodType          String?   @map("blood_type") @db.Char(2)
  emptype            Int?      @map("emptype") @db.SmallInt
  changedDate        DateTime? @map("changed_date")
  commandIdent       Int?      @map("command_ident")
  moveType           Int?      @map("move_type") @db.SmallInt
  workyearSector     Int       @default(0) @map("workyear_sector") @db.SmallInt
  firedreasonIdent   Int?      @map("firedreason_ident")
  takenLeave         Int?      @map("taken_leave") @db.SmallInt
  leaveType          Int?      @map("leave_type") @db.SmallInt
  testMonth          Int?      @map("test_month") @db.SmallInt
  foreignEmp         Int?      @map("foreign_emp") @db.SmallInt
  wagetestEmp        Int?      @map("wagetest_emp") @db.SmallInt
  officeIdent        Int?      @map("office_ident")
  sectionIdent       Int?      @map("section_ident")
  empno              String?   @map("empno") @db.VarChar(10)
  gradePerc          Decimal   @default(0) @map("grade_perc") @db.Decimal(18, 15)
  perc1              Decimal   @default(0) @map("perc1") @db.Decimal(18, 15)
  perc2              Decimal   @default(0) @map("perc2") @db.Decimal(18, 15)
  phone2             String?   @map("phone2") @db.VarChar(14)
  gradeAmount        Decimal   @default(0) @map("grade_amount") @db.Decimal(18, 15)
  gradeStart         DateTime? @map("grade_start")
  gradeEnd           DateTime? @map("grade_end")
  gradeLevel         String?   @map("grade_level") @db.VarChar(10)
  occupationIdent2   Int?      @map("occupation_ident2")
  salPercent         Decimal   @default(0) @map("sal_percent") @db.Decimal(18, 15)
  salAmount          Decimal   @default(0) @map("sal_amount") @db.Decimal(18, 15)
  wtype              Int?      @map("wtype") @db.SmallInt
  disabledEmp        Int?      @map("disabled_emp") @db.SmallInt
  photoUrl           String?   @map("photo_url") @db.VarChar(300)
  posRelated         Boolean?  @map("pos_related")
  etaxCode           String?   @map("etax_code") @db.VarChar(30)
  urgiinOvog         String?   @map("urgiin_ovog") @db.VarChar(100)
  commandNo          String?   @map("command_no") @db.VarChar(10)
  commandDescription String?   @map("command_description") @db.VarChar(100)
  authUsercompanyId  Int?      @map("auth_usercompany_id")
  timetryId          String?   @map("timetry_id") @db.VarChar(25)
  useTimetry         Int?      @map("use_timetry") @db.SmallInt
  authUserId         Int?      @map("auth_user_id")

  dep           Deps?            @relation(fields: [depIdent], references: [depId], onDelete: SetNull)
  workSkill     WorkSkill?       @relation(fields: [wskillIdent], references: [wskillId], onDelete: SetNull)
  occupation    Occupation?      @relation("EmployeeOccupation", fields: [occupationIdent], references: [occupationId], onDelete: SetNull)
  occupation2   Occupation?      @relation("EmployeeOccupation2", fields: [occupationIdent2], references: [occupationId], onDelete: SetNull)
  education     Education?       @relation(fields: [educationIdent], references: [educationId], onDelete: SetNull)
  graduate      Graduate?        @relation(fields: [graduateIdent], references: [graduateId], onDelete: SetNull)
  bank          Banks?           @relation(fields: [bankIdent], references: [bankId], onDelete: SetNull)
  branch        Branch?          @relation(fields: [branchIdent], references: [branchId], onDelete: SetNull)
  shift         Shifts?          @relation(fields: [schedule], references: [id], onDelete: SetNull)
  maritalStatus MaritalStatus?   @relation(fields: [maritalstatusIdent], references: [maritalstatusId], onDelete: SetNull)
  apartmentCond ApartmentCond?   @relation(fields: [apartcondIdent], references: [apartcondId], onDelete: SetNull)
  carownCond    CarownCond?      @relation(fields: [carowncondIdent], references: [carowncondId], onDelete: SetNull)
  nationality   Nationality?     @relation(fields: [nationalityIdent], references: [nationalityId], onDelete: SetNull)
  niigmiinGaral NiigmiinGaral?   @relation(fields: [niigmiinGaralIdent], references: [niigmiinGaralId], onDelete: SetNull)
  country       Country?         @relation(fields: [countryIdent], references: [countryIdent], onDelete: SetNull)
  votingWork    VotingWork?      @relation(fields: [votingWorkIdent], references: [votingWorkId], onDelete: SetNull)
  clothesSize   ClothesSizeType? @relation("EmployeeClothesSize", fields: [clothessizeIdent], references: [typeid], onDelete: SetNull)
  shoesSize     ClothesSizeType? @relation("EmployeeShoesSize", fields: [shoessizeIdent], references: [typeid], onDelete: SetNull)
  insurType     InsurType?       @relation(fields: [insurIdent], references: [insurId], onDelete: SetNull)
  firedReason   FiredReason?     @relation(fields: [firedreasonIdent], references: [firedreasonId], onDelete: SetNull)
  office        HrOffice?        @relation(fields: [officeIdent], references: [officeId], onDelete: SetNull)

  foreignLanguages  ForeignLang[]
  hrTrainings       HrTraining[]
  empPhotos         EmpPhoto[]
  employeeHistories EmployeeHistory[]
  drivers           Driver[]
  educs             Educ[]
  specEdus          SpecEdu[]
  empGrades         EmpGrade[]
  empVacations      EmpVacation[]
  hrAbsents         HrAbsents[]
  commands          Command[]
  empAssets         EmpAssets[]
  empTalents        EmpTalents[]

  @@index([depIdent])
  @@index([occupationIdent])
  @@index([occupationIdent2])
  @@index([educationIdent])
  @@index([graduateIdent])
  @@index([bankIdent])
  @@index([branchIdent])
  @@index([countryIdent])
  @@index([nationalityIdent])
  @@index([maritalstatusIdent])
  @@index([officeIdent])
  @@index([registerno])
  @@index([status])
  @@map("employee")
}

model Deps {
  depId           Int     @id @default(autoincrement()) @map("dep_id") @db.SmallInt
  name            String? @map("name") @db.Char(25)
  parentId        Int?    @map("parent_id") @db.SmallInt
  accNum          String? @map("acc_num") @db.Char(12)
  custIdent       Int?    @map("cust_ident")
  exptypeIdent    Int?    @map("exptype_ident")
  socinsAcc       String? @map("socins_acc") @db.Char(12)
  schedule        Int?    @map("schedule")
  sclass          Int?    @map("sclass") @db.SmallInt
  officeIdent     Int?    @map("office_ident")
  listAcc         String? @map("list_acc") @db.Char(12)
  porder          Int?    @map("porder") @db.SmallInt
  printColumns    String? @map("print_columns") @db.VarChar(500)
  printColumnsAdv String? @map("print_columns_adv") @db.VarChar(500)

  parent    Deps?      @relation("DepsTree", fields: [parentId], references: [depId], onDelete: SetNull)
  children  Deps[]     @relation("DepsTree")
  shift     Shifts?    @relation(fields: [schedule], references: [id], onDelete: SetNull)
  office    HrOffice?  @relation(fields: [officeIdent], references: [officeId], onDelete: SetNull)
  employees Employee[]

  @@index([parentId])
  @@index([schedule])
  @@index([officeIdent])
  @@map("deps")
}

model Occupation {
  occupationId        Int     @id @default(autoincrement()) @map("occupation_id")
  description         String  @map("description") @db.Char(100)
  fdbexpIdent         Int?    @map("fdbexp_ident")
  occup               Int?    @map("occup") @db.SmallInt
  occupationCharacter String? @map("occupation_character") @db.VarChar(20)
  schedId             Int?    @map("sched_id")
  oclassCode          String? @map("oclass_code") @db.VarChar(4)
  oclassCode2024      String? @map("oclass_code2024") @db.VarChar(10)

  schedule   Schedule?  @relation(fields: [schedId], references: [schedId], onDelete: SetNull)
  employees  Employee[] @relation("EmployeeOccupation")
  employees2 Employee[] @relation("EmployeeOccupation2")

  @@index([schedId])
  @@map("occupation")
}

model Education {
  educationId Int    @id @default(autoincrement()) @map("education_id")
  description String @map("description") @db.Char(25)

  employees Employee[]

  @@map("education")
}

model Banks {
  bankId       Int       @id @default(autoincrement()) @map("bank_id")
  description  String?   @map("description") @db.VarChar(100)
  email        String?   @map("email") @db.VarChar(50)
  phone        String?   @map("phone") @db.VarChar(15)
  recacc       String?   @map("recacc") @db.Char(12)
  reccustIdent Int?      @map("reccust_ident")
  bankCode     String?   @map("bank_code") @db.VarChar(20)
  address      String?   @map("address") @db.VarChar(70)
  countryIdent Int?      @map("country_ident")
  modifiedDate DateTime? @map("modified_date")
  bicCode      String?   @map("bic_code") @db.VarChar(20)
  banknumber   String?   @map("banknumber") @db.VarChar(20)
  codeSalary   String?   @map("code_salary") @db.VarChar(20)

  country   Country?   @relation(fields: [countryIdent], references: [countryIdent], onDelete: SetNull)
  employees Employee[]

  @@index([countryIdent])
  @@map("banks")
}

model Country {
  countryIdent Int     @id @default(autoincrement()) @map("country_ident")
  description  String  @map("description") @db.VarChar(50)
  countryCode  String? @map("country_code") @db.VarChar(10)
  code4bank    String? @map("code4bank") @db.VarChar(5)

  employees Employee[]
  banks     Banks[]

  @@map("country")
}

model Nationality {
  nationalityId Int    @id @default(autoincrement()) @map("nationality_id")
  description   String @map("description") @db.Char(50)

  employees Employee[]

  @@map("nationality")
}

model Citytown {
  cityId      Int     @id @default(autoincrement()) @map("city_id")
  description String  @map("description") @db.VarChar(50)
  regionCode  String? @map("region_code") @db.VarChar(10)

  districts District[]

  @@map("citytown")
}

model District {
  districtId  Int     @id @default(autoincrement()) @map("district_id")
  description String  @map("description") @db.VarChar(50)
  code        Int?    @map("code")
  locCode     Int?    @map("loc_code")
  cityIdent   Int     @map("city_ident")
  regionCode  String? @map("region_code") @db.VarChar(10)

  city Citytown @relation(fields: [cityIdent], references: [cityId])

  @@index([cityIdent])
  @@map("district")
}

model MaritalStatus {
  maritalstatusId Int     @id @default(autoincrement()) @map("maritalstatus_id")
  description     String? @map("description") @db.Char(30)
  rplLocal        String? @default("N") @map("rpl_local") @db.Char(1)

  employees Employee[]

  @@map("marital_status")
}

model ApartmentCond {
  apartcondId Int     @id @default(autoincrement()) @map("apartcond_id")
  description String  @map("description") @db.VarChar(50)
  rplLocal    String? @default("N") @map("rpl_local") @db.Char(1)

  employees Employee[]

  @@map("apartment_cond")
}

model CarownCond {
  carowncondId Int     @id @default(autoincrement()) @map("carowncond_id")
  description  String  @map("description") @db.VarChar(50)
  rplLocal     String? @default("N") @map("rpl_local") @db.Char(1)

  employees Employee[]

  @@map("carown_cond")
}

model NiigmiinGaral {
  niigmiinGaralId Int     @id @default(autoincrement()) @map("niigmiin_garal_id")
  description     String  @map("description") @db.VarChar(50)
  rplLocal        String? @default("N") @map("rpl_local") @db.Char(1)

  employees Employee[]

  @@map("niigmiin_garal")
}

model VotingWork {
  votingWorkId Int    @id @default(autoincrement()) @map("voting_work_id")
  description  String @map("description") @db.VarChar(50)

  employees Employee[]

  @@map("voting_work")
}

model Graduate {
  graduateId  Int    @id @default(autoincrement()) @map("graduate_id")
  description String @map("description") @db.Char(25)

  employees Employee[]

  @@map("graduate")
}

model InsurType {
  insurId      Int      @id @default(autoincrement()) @map("insur_id")
  insurCode    String?  @map("insur_code") @db.VarChar(10)
  description  String?  @map("description") @db.VarChar(100)
  salType      Int?     @map("sal_type") @db.SmallInt
  insOrder     Int?     @map("ins_order")
  colnum       Int?     @map("colnum") @db.SmallInt
  ndshPercent  Decimal? @map("ndsh_percent") @db.Decimal(18, 2)
  empPercent   Decimal? @map("emp_percent") @db.Decimal(18, 2)
  insurCodenew String?  @map("insur_codenew") @db.VarChar(10)

  employees Employee[]

  @@map("insur_type")
}

model FiredReason {
  firedreasonId Int    @id @default(autoincrement()) @map("firedreason_id")
  description   String @map("description") @db.VarChar(100)

  employees Employee[]

  @@map("fired_reason")
}

model ClothesSizeType {
  typeid         Int     @id @default(autoincrement()) @map("typeid")
  clothessize    String  @map("clothessize") @db.Char(10)
  sizetype       String  @map("sizetype") @db.Char(7)
  sizeOtherMan   String? @map("size_other_man") @db.Char(10)
  sizeOtherWoman String? @map("size_other_woman") @db.Char(10)

  clothesEmployees Employee[] @relation("EmployeeClothesSize")
  shoesEmployees   Employee[] @relation("EmployeeShoesSize")

  @@map("clothes_size_type")
}

model WorkSkill {
  wskillId    Int     @id @default(autoincrement()) @map("wskill_id")
  description String  @map("description") @db.Char(25)
  costNormal  Decimal @default(0) @map("cost_normal") @db.Decimal(18, 15)
  costHard    Decimal @default(0) @map("cost_hard") @db.Decimal(18, 15)
  costOther   Decimal @default(0) @map("cost_other") @db.Decimal(18, 15)

  employees Employee[]

  @@map("work_skill")
}

model Branch {
  branchId        Int       @id @default(autoincrement()) @map("branch_id")
  description     String    @map("description") @db.Char(25)
  boss            String?   @map("boss") @db.Char(30)
  genAccountant   String?   @map("gen_accountant") @db.Char(30)
  status          Int       @map("status") @db.SmallInt
  legalName       String?   @map("legal_name") @db.Char(40)
  address         String?   @map("address") @db.Char(90)
  registerno      String?   @map("registerno") @db.Char(20)
  ttd             String?   @map("ttd") @db.Char(20)
  orgType         String?   @map("org_type") @db.Char(25)
  accountant      String?   @map("accountant") @db.Char(25)
  custid          Int?      @map("custid")
  manager         Int?      @map("manager")
  bankname        String?   @map("bankname") @db.VarChar(30)
  banknumber      String?   @map("banknumber") @db.VarChar(20)
  phone           String?   @map("phone") @db.VarChar(60)
  hrmanager       String?   @map("hrmanager") @db.VarChar(30)
  tradeunionName  String?   @map("tradeunion_name") @db.VarChar(100)
  tradeunionAssoc String?   @map("tradeunion_assoc") @db.VarChar(100)
  tradeunionHead  String?   @map("tradeunion_head") @db.VarChar(100)
  chkdate         DateTime? @map("chkdate")
  logo            Bytes?    @map("logo")
  isSync          String?   @map("is_sync") @db.VarChar(3)
  modifiedDate    DateTime? @map("modified_date")
  bossSign1       Bytes?    @map("boss_sign1")
  accountSign1    Bytes?    @map("account_sign1")
  stampAcc        Bytes?    @map("stamp_acc")
  stampBoss       Bytes?    @map("stamp_boss")
  emdCust         Int?      @map("emd_cust")
  emdacc          String?   @map("emdacc") @db.Char(12)
  taxable         String?   @map("taxable") @db.VarChar(12)
  email           String?   @map("email") @db.VarChar(100)

  employees Employee[]

  @@map("branch")
}

model HrOffice {
  officeId Int    @id @default(autoincrement()) @map("office_id")
  name     String @map("name") @db.VarChar(100)

  deps      Deps[]
  employees Employee[]

  @@map("hr_office")
}

model Shifts {
  id   Int    @id @default(autoincrement()) @map("id")
  name String @map("name") @db.VarChar(20)

  deps      Deps[]
  employees Employee[]

  @@map("shifts")
}

model Schedule {
  schedId   Int    @id @default(autoincrement()) @map("sched_id")
  schedName String @map("sched_name") @db.VarChar(30)
  workDay   Int    @map("work_day")
  holiday   Int    @map("holiday")

  occupations Occupation[]

  @@map("schedule")
}

model ProfessionType {
  professiontypeId Int    @id @default(autoincrement()) @map("professiontype_id")
  description      String @map("description") @db.Char(100)

  @@map("profession_type")
}

model EduType {
  educationId Int     @id @default(autoincrement()) @map("education_id")
  name        String  @map("name") @db.VarChar(50)
  rplLocal    String? @default("N") @map("rpl_local") @db.Char(1)

  educs Educ[]

  @@map("edu_type")
}

model Educ {
  educId        Int       @id @default(autoincrement()) @map("educ_id") @db.SmallInt
  employeeIdent Int       @map("employee_ident")
  eduIdent      Int       @map("edu_ident")
  startdate     DateTime? @map("startdate")
  startYear     Int       @map("start_year") @db.SmallInt

  employee Employee @relation(fields: [employeeIdent], references: [employeeId], onDelete: Cascade)
  eduType  EduType  @relation(fields: [eduIdent], references: [educationId])

  @@index([employeeIdent])
  @@index([eduIdent])
  @@map("educ")
}

model SpecEduType {
  specEduTypeId Int    @id @default(autoincrement()) @map("spec_edu_type_id")
  description   String @map("description") @db.Char(30)

  specEdus SpecEdu[]

  @@map("spec_edu_type")
}

model SpecEdu {
  specEduId        Int       @id @default(autoincrement()) @map("spec_edu_id")
  employeeIdent    Int       @map("employee_ident")
  specEduTypeIdent Int       @map("spec_edu_type_ident")
  orgEdu           String    @map("org_edu") @db.VarChar(30)
  certifyNumber    String?   @map("certify_number") @db.Char(20)
  certifyDate      DateTime? @map("certify_date")
  profession       String?   @map("profession") @db.VarChar(20)
  endDate          DateTime? @map("end_date")
  specProfession   String?   @map("spec_profession") @db.VarChar(20)
  certifyYear      Int       @map("certify_year") @db.SmallInt

  employee    Employee    @relation(fields: [employeeIdent], references: [employeeId], onDelete: Cascade)
  specEduType SpecEduType @relation(fields: [specEduTypeIdent], references: [specEduTypeId])

  @@index([employeeIdent])
  @@index([specEduTypeIdent])
  @@map("spec_edu")
}

model Flanguages {
  flanguageId Int     @id @default(autoincrement()) @map("flanguage_id")
  description String  @map("description") @db.Char(30)
  rplLocal    String? @default("N") @map("rpl_local") @db.Char(1)

  foreignLangs ForeignLang[]

  @@map("flanguages")
}

model LangLevel {
  langlevelId Int    @id @default(autoincrement()) @map("langlevel_id")
  levelName   String @map("level_name") @db.VarChar(50)

  @@map("lang_level")
}

model ForeignLang {
  foreignlangId  Int     @id @default(autoincrement()) @map("foreignlang_id")
  employeeIdent  Int     @map("employee_ident")
  flanguageIdent Int     @map("flanguage_ident")
  understandLvl  String? @map("understand_lvl") @db.Char(15)
  speakingLvl    String? @map("speaking_lvl") @db.Char(15)
  readingLvl     String? @map("reading_lvl") @db.Char(15)
  writingLvl     String? @map("writing_lvl") @db.Char(15)
  description    String? @map("description") @db.VarChar(50)

  employee Employee   @relation(fields: [employeeIdent], references: [employeeId], onDelete: Cascade)
  language Flanguages @relation(fields: [flanguageIdent], references: [flanguageId])

  @@index([employeeIdent])
  @@index([flanguageIdent])
  @@map("foreign_lang")
}

model HrTraining {
